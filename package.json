{
  "name": "soma-projects",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3110",
    "build": "node scripts/validate-project-data.mjs && vite build --ssr src/entry-server.tsx --outDir .ssg/server && vite build --outDir out --manifest && node scripts/generate-static.mjs && node scripts/verify-static-output.mjs",
    "typecheck": "node scripts/validate-project-data.mjs && tsc --noEmit",
    "validate:data": "node scripts/validate-project-data.mjs",
    "verify:static": "node scripts/verify-static-output.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.454.0",
    "react": "^18.0",
    "react-dom": "^18.0",
    "react-markdown": "latest"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vite": "^8.0.14"
  }
}
